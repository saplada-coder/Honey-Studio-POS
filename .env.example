# ============================================================
# HONEY STUDIO POS — Environment Variables (ตัวอย่าง / TEMPLATE)
# ============================================================
# ไฟล์นี้เป็น "ตัวอย่าง" ไม่มีความลับ — ขึ้น GitHub ได้
# วิธีใช้: คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่าจริงลงไป
#   cp .env.example .env.local
# ============================================================

# ฐานข้อมูล Neon Postgres (Vercel → Storage → Neon)
DATABASE_URL="postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ที่เก็บไฟล์ Vercel Blob (Vercel → Storage → Blob → Tokens)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxx"

# ความลับสำหรับระบบล็อกอิน (สุ่มด้วย: openssl rand -base64 32)
AUTH_SECRET="change-me-random-string"

# ค่าตั้งทั่วไป (เปิดเผยได้)
NEXT_PUBLIC_APP_NAME="HONEY STUDIO"
